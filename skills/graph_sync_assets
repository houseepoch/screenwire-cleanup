#!/usr/bin/env python3
"""graph_sync_assets — Sync generated asset paths from manifest back into the graph.

After Image Verifier (Phase 3) generates composites/locations/props,
their file paths are in the manifest but NOT in the graph.
This script reads the manifest and updates the graph so that
prompt assembly can resolve ref_images correctly.

Usage:
    python3 $SKILLS_DIR/graph_sync_assets --project-dir .
"""

import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.store import GraphStore


def main():
    import argparse
    parser = argparse.ArgumentParser()
    parser.add_argument("--project-dir", default=os.getcwd())
    args = parser.parse_args()

    project_dir = args.project_dir
    manifest_path = os.path.join(project_dir, "project_manifest.json")

    if not os.path.exists(manifest_path):
        print("ERROR: project_manifest.json not found")
        sys.exit(1)

    manifest = json.loads(open(manifest_path, encoding="utf-8").read())
    store = GraphStore(project_dir)
    graph = store.load()

    synced = 0

    # Sync cast composite paths
    for mc in manifest.get("cast", []):
        cast_id = mc.get("castId")
        comp_path = mc.get("compositePath")
        if cast_id and comp_path and cast_id in graph.cast:
            if graph.cast[cast_id].composite_path != comp_path:
                graph.cast[cast_id].composite_path = comp_path
                graph.cast[cast_id].composite_status = "generated"
                synced += 1
                print(f"  Synced cast composite: {cast_id} -> {comp_path}")

        voice_path = mc.get("voiceProfilePath")
        if cast_id and voice_path and cast_id in graph.cast:
            if graph.cast[cast_id].voice_profile_path != voice_path:
                graph.cast[cast_id].voice_profile_path = voice_path
                graph.cast[cast_id].voice_status = "profiled"
                synced += 1

    # Sync location image paths
    for ml in manifest.get("locations", []):
        loc_id = ml.get("locationId")
        img_path = ml.get("primaryImagePath")
        if loc_id and img_path and loc_id in graph.locations:
            if graph.locations[loc_id].primary_image_path != img_path:
                graph.locations[loc_id].primary_image_path = img_path
                graph.locations[loc_id].image_status = "generated"
                synced += 1
                print(f"  Synced location image: {loc_id} -> {img_path}")

    # Sync prop image paths
    for mp in manifest.get("props", []):
        prop_id = mp.get("propId")
        img_path = mp.get("imagePath")
        if prop_id and img_path and prop_id in graph.props:
            if graph.props[prop_id].image_path != img_path:
                graph.props[prop_id].image_path = img_path
                synced += 1
                print(f"  Synced prop image: {prop_id} -> {img_path}")

    # Sync frame composed image paths
    for mf in manifest.get("frames", []):
        frame_id = mf.get("frameId")
        img_path = mf.get("generatedImagePath")
        if frame_id and img_path and frame_id in graph.frames:
            if graph.frames[frame_id].composed_image_path != img_path:
                graph.frames[frame_id].composed_image_path = img_path
                synced += 1

    store.save(graph)
    print(f"SUCCESS: Synced {synced} asset paths from manifest into graph")


if __name__ == "__main__":
    main()
