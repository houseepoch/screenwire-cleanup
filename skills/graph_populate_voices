#!/usr/bin/env python3
"""graph_populate_voices — Create VoiceNode entries for all speaking cast members.

Reads CastNode entries from the graph, creates a VoiceNode for each cast member
that has voice data (voice_description or dialogue lines), and saves back.

Usage:
    python3 $SKILLS_DIR/graph_populate_voices --project-dir .
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.schema import VoiceNode, Provenance
from graph.store import GraphStore


def main():
    parser = argparse.ArgumentParser(description="Populate VoiceNode entries from cast data")
    parser.add_argument("--project-dir", default=os.getcwd())
    args = parser.parse_args()

    store = GraphStore(args.project_dir)
    graph = store.load()

    created = 0
    skipped = 0

    for cast_id, cast_node in graph.cast.items():
        # Skip if voice node already exists
        if cast_id in graph.voices:
            skipped += 1
            continue

        # Only create voice nodes for cast with voice data or dialogue
        has_voice_data = bool(cast_node.voice.voice_description)
        has_dialogue = cast_node.dialogue_line_count > 0
        if not has_voice_data and not has_dialogue:
            continue

        voice = VoiceNode(
            voice_id=cast_id,
            cast_id=cast_id,
            character_name=cast_node.name,
            voice_description=cast_node.voice.voice_description,
            quality_prefix=cast_node.voice.quality_prefix,
            tone=cast_node.voice.tone,
            pitch=cast_node.voice.pitch,
            accent=cast_node.voice.accent,
            delivery_style=cast_node.voice.delivery_style,
            tempo=cast_node.voice.tempo,
            emotional_range=cast_node.voice.emotional_range,
            vocal_style=cast_node.voice.vocal_style,
            voice_profile_path=cast_node.voice_profile_path,
            voice_status=cast_node.voice_status or "pending",
            provenance=Provenance(source="graph_populate_voices"),
        )

        graph.voices[cast_id] = voice
        created += 1
        print(f"  Created voice node: {cast_id} ({cast_node.name})")

    store.save(graph)
    print(f"SUCCESS: Created {created} voice nodes, skipped {skipped} existing")


if __name__ == "__main__":
    main()
