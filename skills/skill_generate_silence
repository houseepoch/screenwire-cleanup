#!/usr/bin/env python3
"""skill_generate_silence — Generate a silent audio file of a given duration using ffmpeg."""

import argparse
import subprocess
import sys


def main():
    parser = argparse.ArgumentParser(description="Generate a silent MP3 audio file using ffmpeg.")
    parser.add_argument("--duration", type=float, required=True, help="Duration of silence in seconds")
    parser.add_argument("--out", required=True, help="Output audio file path")
    args = parser.parse_args()

    cmd = [
        "ffmpeg", "-y",
        "-f", "lavfi",
        "-i", "anullsrc=r=44100:cl=stereo",
        "-t", str(args.duration),
        "-c:a", "libmp3lame",
        "-b:a", "128k",
        args.out,
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
    except FileNotFoundError:
        print("ERROR: ffmpeg not found. Please install ffmpeg.")
        sys.exit(1)

    if result.returncode != 0:
        print(f"ERROR: ffmpeg failed: {result.stderr.strip()}")
        sys.exit(1)

    print(f"SUCCESS: Silence generated ({args.duration}s) -> {args.out}")


if __name__ == "__main__":
    main()
