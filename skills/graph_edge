#!/usr/bin/env python3
"""graph_edge — Create or close edges in the narrative graph.

Usage:
    python3 graph_edge --create --source cast_001_mei --target f_014 --edge-type appears_in --prose "Mei crosses to the window"
    python3 graph_edge --create --source cast_001_mei --target prop_003_letter --edge-type possession --start-frame f_003 --prose "Mei picks up the letter"
    python3 graph_edge --close --source cast_001_mei --target prop_003_letter --edge-type possession --end-frame f_028
"""

import argparse
import json
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.store import GraphStore
from graph.api import create_edge, close_temporal_edge


def main():
    parser = argparse.ArgumentParser(description="Manage graph edges")
    parser.add_argument("--project-dir", default=os.getcwd())

    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--create", action="store_true")
    group.add_argument("--close", action="store_true")

    parser.add_argument("--source", required=True)
    parser.add_argument("--target", required=True)
    parser.add_argument("--edge-type", required=True)
    parser.add_argument("--weight", type=float, default=1.0)
    parser.add_argument("--start-frame", default=None)
    parser.add_argument("--end-frame", default=None)
    parser.add_argument("--prose", default="", help="Source prose chunk (required for --create)")
    parser.add_argument("--agent", default="morpheus", help="Agent creating this edge")
    args = parser.parse_args()

    store = GraphStore(args.project_dir)
    graph = store.load()

    if args.create:
        if not args.prose.strip():
            print("ERROR: --prose is required for edge creation (provenance).")
            sys.exit(1)

        provenance = {
            "source_prose_chunk": args.prose,
            "generated_by": args.agent,
            "confidence": 1.0,
        }
        edge = create_edge(
            graph, args.source, args.target, args.edge_type,
            provenance=provenance, weight=args.weight,
            start_frame=args.start_frame, end_frame=args.end_frame,
        )
        print(f"SUCCESS: Edge created -> {edge.edge_id}")

    elif args.close:
        if not args.end_frame:
            print("ERROR: --end-frame required for closing temporal edges.")
            sys.exit(1)

        closed = close_temporal_edge(
            graph, args.source, args.target, args.edge_type, args.end_frame
        )
        if closed:
            print(f"SUCCESS: Edge closed -> {args.source} --{args.edge_type}--> {args.target} ends at {args.end_frame}")
        else:
            print(f"WARNING: No open edge found for {args.source} --{args.edge_type}--> {args.target}")

    store.save(graph)


if __name__ == "__main__":
    main()
