#!/usr/bin/env python3
"""graph_generate_assets — Programmatically generate all cast, location, and prop images from pre-built prompts.

Reads prompt JSONs from cast/prompts/, locations/prompts/, props/prompts/
and fires generation requests to the server in parallel batches.

Usage:
    python3 graph_generate_assets --project-dir . [--batch-size 10] [--skip-existing]
"""

import argparse
import asyncio
import json
import os
import sys
from pathlib import Path

import httpx


SERVER_URL = "http://localhost:8000"


async def generate_one(client: httpx.AsyncClient, prompt_data: dict, project_dir: Path) -> dict:
    """Generate a single image from a prompt JSON."""
    prompt = prompt_data["prompt"]
    size = prompt_data.get("size", "landscape_16_9")
    out_path = prompt_data.get("out_path", "")
    generation_mode = prompt_data.get("generation_mode", "")

    out_abs = project_dir / out_path
    out_abs.parent.mkdir(parents=True, exist_ok=True)

    # Map size presets
    aspect_map = {
        "landscape_16_9": "16:9", "landscape_4_3": "4:3", "landscape_3_2": "3:2",
        "portrait_9_16": "9:16", "portrait_3_4": "3:4", "portrait_2_3": "2:3",
        "square": "1:1", "square_hd": "1:1",
    }
    aspect = aspect_map.get(size, "16:9")

    # Resolve reference images (used by frame generation and location direction edits)
    raw_refs = prompt_data.get("ref_images", [])
    resolved_refs = []
    for ref in raw_refs:
        ref_path = project_dir / ref
        if ref_path.exists():
            resolved_refs.append(str(ref_path))

    endpoint = "/internal/generate-frame"
    body = {
        "prompt": prompt,
        "aspect_ratio": aspect,
        "output_path": str(out_abs),
        "output_format": "png",
        "reference_images": resolved_refs,
    }

    if generation_mode == "p_image_edit":
        input_path = prompt_data.get("input_path", "")
        if not input_path:
            return {
                "success": False,
                "path": str(out_abs),
                "error": "direction prompt missing input_path",
            }
        source_abs = project_dir / input_path
        if not source_abs.exists():
            return {
                "success": False,
                "path": str(out_abs),
                "error": f"source image not found: {source_abs}",
            }
        endpoint = "/internal/generate-location-direction"
        body = {
            "prompt": prompt,
            "input_path": str(source_abs),
            "image_size": size,
            "output_path": str(out_abs),
            "output_format": "png",
            "reference_images": resolved_refs,
        }

    try:
        resp = await client.post(f"{SERVER_URL}{endpoint}", json=body, timeout=180)
        if resp.status_code == 502:
            detail = "502 prediction failure"
            try:
                payload = resp.json()
                detail = payload.get("detail", detail)
            except Exception:
                if resp.text:
                    detail = resp.text
            return {"success": False, "path": str(out_abs), "error": detail}
        resp.raise_for_status()
        return {"success": True, "path": str(out_abs)}
    except Exception as e:
        return {"success": False, "path": str(out_abs), "error": str(e)}


async def generate_batch(prompts: list[dict], project_dir: Path, batch_size: int) -> tuple[int, int]:
    """Generate images in parallel batches."""
    success = 0
    failed = 0

    async with httpx.AsyncClient() as client:
        for i in range(0, len(prompts), batch_size):
            batch = prompts[i:i + batch_size]
            tasks = [generate_one(client, p, project_dir) for p in batch]
            results = await asyncio.gather(*tasks, return_exceptions=True)

            for r in results:
                if isinstance(r, Exception):
                    failed += 1
                    print(f"  ERROR: {r}")
                elif r.get("success"):
                    success += 1
                    print(f"  OK: {Path(r['path']).name}")
                else:
                    failed += 1
                    print(f"  FAIL: {Path(r['path']).name} — {r.get('error', 'unknown')}")

    return success, failed


def load_prompts(prompt_dir: Path) -> list[dict]:
    """Load all JSON prompt files from a directory."""
    prompts = []
    if not prompt_dir.exists():
        return prompts
    for f in sorted(prompt_dir.glob("*.json")):
        try:
            prompts.append(json.loads(f.read_text(encoding="utf-8")))
        except Exception as e:
            print(f"  WARNING: Failed to read {f.name}: {e}")
    return prompts


def main():
    parser = argparse.ArgumentParser(description="Generate all asset images from pre-built prompts.")
    parser.add_argument("--project-dir", default=os.getcwd())
    parser.add_argument("--batch-size", type=int, default=10)
    parser.add_argument("--skip-existing", action="store_true",
                        help="Skip generation if output file already exists")
    parser.add_argument("--types", default="all",
                        help="Comma-separated asset types to generate: cast,locations,direction,props (default: all)")
    args = parser.parse_args()

    project_dir = Path(args.project_dir)
    types = set(args.types.split(",")) if args.types != "all" else {"cast", "locations", "direction", "props"}

    # Load prompt files for requested types only
    cast_prompts = load_prompts(project_dir / "cast" / "prompts") if "cast" in types else []
    loc_prompts = load_prompts(project_dir / "locations" / "prompts") if "locations" in types else []
    loc_dir_prompts = load_prompts(project_dir / "locations" / "direction_prompts") if "direction" in types else []
    prop_prompts = load_prompts(project_dir / "props" / "prompts") if "props" in types else []

    # Filter existing if requested
    if args.skip_existing:
        cast_prompts = [p for p in cast_prompts if not (project_dir / p["out_path"]).exists()]
        loc_prompts = [p for p in loc_prompts if not (project_dir / p["out_path"]).exists()]
        loc_dir_prompts = [p for p in loc_dir_prompts if not (project_dir / p["out_path"]).exists()]
        prop_prompts = [p for p in prop_prompts if not (project_dir / p["out_path"]).exists()]

    total = len(cast_prompts) + len(loc_prompts) + len(loc_dir_prompts) + len(prop_prompts)
    print(f"Generating {total} assets: {len(cast_prompts)} cast, {len(loc_prompts)} locations, {len(loc_dir_prompts)} direction views, {len(prop_prompts)} props")

    all_success = 0
    all_failed = 0

    if cast_prompts:
        print(f"\n--- Cast Composites ({len(cast_prompts)}) ---")
        s, f = asyncio.run(generate_batch(cast_prompts, project_dir, args.batch_size))
        all_success += s
        all_failed += f

    if loc_prompts:
        print(f"\n--- Locations — Primary ({len(loc_prompts)}) ---")
        s, f = asyncio.run(generate_batch(loc_prompts, project_dir, args.batch_size))
        all_success += s
        all_failed += f

    # Directional views AFTER primary locations (they reference the primary image)
    if loc_dir_prompts:
        print(f"\n--- Locations — Direction Views ({len(loc_dir_prompts)}) ---")
        s, f = asyncio.run(generate_batch(loc_dir_prompts, project_dir, args.batch_size))
        all_success += s
        all_failed += f

    if prop_prompts:
        print(f"\n--- Props ({len(prop_prompts)}) ---")
        s, f = asyncio.run(generate_batch(prop_prompts, project_dir, args.batch_size))
        all_success += s
        all_failed += f

    print(f"\nSUCCESS: Generated {all_success}/{total} assets ({all_failed} failed)")

    if all_failed > 0:
        sys.exit(1)


if __name__ == "__main__":
    main()
