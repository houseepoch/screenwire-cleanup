#!/usr/bin/env python3
"""skill_slice_audio — Slice a segment from an audio file using ffmpeg."""

import argparse
import subprocess
import sys


def main():
    parser = argparse.ArgumentParser(description="Slice a segment from an audio file using ffmpeg.")
    parser.add_argument("--input", required=True, help="Input audio file path")
    parser.add_argument("--start", type=float, required=True, help="Start time in seconds")
    parser.add_argument("--end", type=float, required=True, help="End time in seconds")
    parser.add_argument("--out", required=True, help="Output audio file path")
    args = parser.parse_args()

    cmd = [
        "ffmpeg", "-y",
        "-i", args.input,
        "-ss", str(args.start),
        "-to", str(args.end),
        "-c:a", "libmp3lame",
        "-b:a", "128k",
        args.out,
    ]

    try:
        result = subprocess.run(cmd, capture_output=True, text=True)
    except FileNotFoundError:
        print("ERROR: ffmpeg not found. Please install ffmpeg.")
        sys.exit(1)

    if result.returncode != 0:
        print(f"ERROR: ffmpeg failed: {result.stderr.strip()}")
        sys.exit(1)

    print(f"SUCCESS: Audio sliced [{args.start}s -> {args.end}s] -> {args.out}")


if __name__ == "__main__":
    main()
