#!/usr/bin/env python3
"""graph_build_chains — Build chained frame groups in the narrative graph.

Identifies sequences of 2+ consecutive frames sharing the same scene_id
and location_id, registers them as ChainedFrameGroup entries, and saves.

Usage:
    python3 $SKILLS_DIR/graph_build_chains --project-dir .
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.api import build_chained_frame_groups
from graph.store import GraphStore


def main():
    parser = argparse.ArgumentParser(description="Build chained frame groups")
    parser.add_argument("--project-dir", default=os.getcwd())
    args = parser.parse_args()

    store = GraphStore(args.project_dir)
    graph = store.load()

    chains = build_chained_frame_groups(graph)

    store.save(graph)
    print(f"SUCCESS: Built {len(chains)} chained frame groups")
    for chain in chains:
        print(f"  {chain.chain_id}: {chain.frame_count} frames at {chain.location_id} in {chain.scene_id}")


if __name__ == "__main__":
    main()
