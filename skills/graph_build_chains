#!/usr/bin/env python3
"""graph_build_chains — Backward-compatible shim for storyboard grid building.

Legacy entrypoint retained so older scripts do not fail after the
ChainedFrameGroup -> StoryboardGrid migration.

Usage:
    python3 $SKILLS_DIR/graph_build_chains --project-dir .
"""

import argparse
import os
import sys

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.api import build_storyboard_grids
from graph.store import GraphStore


def main():
    parser = argparse.ArgumentParser(
        description="Build storyboard grids (legacy graph_build_chains alias)"
    )
    parser.add_argument("--project-dir", default=os.getcwd())
    args = parser.parse_args()

    store = GraphStore(args.project_dir)
    graph = store.load()

    grids = build_storyboard_grids(graph)

    store.save(graph)
    print("WARNING: graph_build_chains is deprecated; use graph_build_grids instead.")
    print(f"SUCCESS: Built {len(grids)} storyboard grids")
    for grid in grids:
        scene_label = ",".join(grid.scene_ids) if grid.scene_ids else "no_scene"
        print(f"  {grid.grid_id}: {grid.frame_count} frames across {scene_label}")


if __name__ == "__main__":
    main()
