#!/usr/bin/env python3
"""graph_batch — Execute a batch of graph operations from a JSON file.

Instead of calling graph_upsert 50+ times (one CLI call per node),
Morpheus writes a single JSON operations file and runs this once.

Usage:
    python3 $SKILLS_DIR/graph_batch --ops-file ops.json --project-dir .

Operations file format:
{
  "operations": [
    {"op": "upsert_node", "type": "cast", "data": {...}, "provenance": {...}},
    {"op": "upsert_node", "type": "frame", "data": {...}, "provenance": {...}},
    {"op": "upsert_state", "type": "cast_frame_state", "data": {...}, "provenance": {...}},
    {"op": "create_edge", "source": "...", "target": "...", "edge_type": "...", "provenance": {...}},
    {"op": "close_edge", "source": "...", "target": "...", "edge_type": "...", "end_frame": "..."},
    {"op": "propagate_cast", "cast_id": "...", "from_frame": "...", "to_frame": "...", "mutations": {...}, "provenance": {...}},
    {"op": "propagate_prop", "prop_id": "...", "from_frame": "...", "to_frame": "...", "mutations": {...}, "provenance": {...}},
    {"op": "propagate_location", "location_id": "...", "from_frame": "...", "to_frame": "...", "mutations": {...}, "provenance": {...}}
  ]
}
"""

import argparse
import json
import os
import sys
import traceback

sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from graph.store import GraphStore
from graph.api import (
    upsert_node, upsert_frame_state, create_edge, close_temporal_edge,
    propagate_cast_state, propagate_prop_state, propagate_location_state,
)


def main():
    parser = argparse.ArgumentParser(description="Batch graph operations")
    parser.add_argument("--ops-file", required=True, help="Path to JSON operations file")
    parser.add_argument("--project-dir", default=os.getcwd())
    args = parser.parse_args()

    # Read operations
    ops_path = args.ops_file
    if not os.path.isabs(ops_path):
        ops_path = os.path.join(args.project_dir, ops_path)

    with open(ops_path, "r", encoding="utf-8") as f:
        content = f.read()
        # Strip markdown fences if present
        if content.strip().startswith("```"):
            lines = content.strip().split("\n")
            lines = [l for l in lines if not l.strip().startswith("```")]
            content = "\n".join(lines)
        ops_data = json.loads(content)

    operations = ops_data.get("operations", [])
    if not operations:
        print("ERROR: No operations found in file")
        sys.exit(1)

    store = GraphStore(args.project_dir)
    graph = store.load()

    succeeded = 0
    failed = 0
    errors = []

    for i, op in enumerate(operations):
        try:
            op_type = op.get("op")

            if op_type == "upsert_node":
                node_id = upsert_node(graph, op["type"], op["data"], op.get("provenance", {}))
                succeeded += 1

            elif op_type == "upsert_state":
                key = upsert_frame_state(graph, op["type"], op["data"], op.get("provenance", {}))
                succeeded += 1

            elif op_type == "create_edge":
                edge = create_edge(
                    graph, op["source"], op["target"], op["edge_type"],
                    provenance=op.get("provenance", {}),
                    weight=op.get("weight", 1.0),
                    start_frame=op.get("start_frame"),
                    end_frame=op.get("end_frame"),
                )
                succeeded += 1

            elif op_type == "close_edge":
                closed = close_temporal_edge(
                    graph, op["source"], op["target"], op["edge_type"], op["end_frame"]
                )
                succeeded += 1

            elif op_type == "propagate_cast":
                propagate_cast_state(
                    graph, op["cast_id"], op["from_frame"], op["to_frame"],
                    mutations=op.get("mutations"),
                    provenance=op.get("provenance", {}),
                )
                succeeded += 1

            elif op_type == "propagate_prop":
                propagate_prop_state(
                    graph, op["prop_id"], op["from_frame"], op["to_frame"],
                    mutations=op.get("mutations"),
                    provenance=op.get("provenance", {}),
                )
                succeeded += 1

            elif op_type == "propagate_location":
                propagate_location_state(
                    graph, op["location_id"], op["from_frame"], op["to_frame"],
                    mutations=op.get("mutations"),
                    provenance=op.get("provenance", {}),
                )
                succeeded += 1

            else:
                errors.append(f"Op {i}: Unknown operation type '{op_type}'")
                failed += 1

        except Exception as e:
            errors.append(f"Op {i} ({op.get('op', '?')}): {e}")
            failed += 1

    # Save graph
    store.save(graph)

    # Report
    print(f"SUCCESS: Batch complete — {succeeded} succeeded, {failed} failed out of {len(operations)}")
    print(f"  Graph: {len(graph.cast)} cast, {len(graph.locations)} locations, "
          f"{len(graph.props)} props, {len(graph.scenes)} scenes, "
          f"{len(graph.frames)} frames, {len(graph.dialogue)} dialogue, "
          f"{len(graph.edges)} edges")
    print(f"  States: {len(graph.cast_frame_states)} cast, "
          f"{len(graph.prop_frame_states)} prop, "
          f"{len(graph.location_frame_states)} location")

    if errors:
        print(f"\nErrors ({len(errors)}):")
        for err in errors[:20]:
            print(f"  - {err}")

    if failed > 0:
        sys.exit(1)


if __name__ == "__main__":
    main()
