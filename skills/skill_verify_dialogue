#!/usr/bin/env python3
"""skill_verify_dialogue — Verify TTS audio matches expected dialogue text.

Checks that audio duration is reasonable for the text length. If audio is
too long (bracket directions were spoken, or extra content was generated),
reports the issue with expected vs actual duration.

Can optionally trim audio to a max duration using ffmpeg.

Usage:
    python3 skill_verify_dialogue --audio path.mp3 --text "expected dialogue text" [--max-duration 5.0] [--trim]
"""

import argparse
import json
import os
import subprocess
import sys


def _get_duration(audio_path: str) -> float:
    """Get audio duration in seconds using ffprobe."""
    result = subprocess.run(
        ["ffprobe", "-v", "error", "-show_entries", "format=duration",
         "-of", "json", audio_path],
        capture_output=True, text=True, timeout=10
    )
    if result.returncode != 0:
        return -1.0
    data = json.loads(result.stdout)
    return float(data.get("format", {}).get("duration", 0))


def _estimate_speech_duration(text: str) -> float:
    """Estimate expected speech duration from word count.

    Average English speech: ~150 words/minute = 2.5 words/second.
    Add 20% buffer for pauses and emphasis.
    """
    words = len(text.split())
    base = words / 2.5  # seconds
    return base * 1.2  # with buffer


def _trim_audio(audio_path: str, max_duration: float) -> bool:
    """Trim audio to max_duration using ffmpeg. Overwrites in place."""
    tmp = audio_path + ".trim.tmp"
    result = subprocess.run(
        ["ffmpeg", "-y", "-i", audio_path, "-t", str(max_duration),
         "-c", "copy", tmp],
        capture_output=True, text=True, timeout=30
    )
    if result.returncode == 0 and os.path.exists(tmp):
        os.replace(tmp, audio_path)
        return True
    if os.path.exists(tmp):
        os.remove(tmp)
    return False


def main():
    parser = argparse.ArgumentParser(description="Verify TTS audio against expected dialogue.")
    parser.add_argument("--audio", required=True, help="Path to audio file")
    parser.add_argument("--text", required=True, help="Expected dialogue text (clean, no brackets)")
    parser.add_argument("--max-duration", type=float, default=0, help="Max allowed duration in seconds (0=auto)")
    parser.add_argument("--trim", action="store_true", help="Auto-trim if audio exceeds max duration")
    args = parser.parse_args()

    if not os.path.exists(args.audio):
        print(f"ERROR: Audio file not found: {args.audio}")
        sys.exit(1)

    actual_duration = _get_duration(args.audio)
    if actual_duration < 0:
        print(f"ERROR: Could not read audio duration: {args.audio}")
        sys.exit(1)

    expected_duration = _estimate_speech_duration(args.text)
    max_duration = args.max_duration if args.max_duration > 0 else expected_duration * 2.0

    # Check file size
    file_size = os.path.getsize(args.audio)
    if file_size < 1024:
        print(f"WARNING: Audio file is very small ({file_size} bytes) — may be corrupt or empty")

    # Evaluate
    ratio = actual_duration / expected_duration if expected_duration > 0 else 0
    status = "OK"

    if actual_duration > max_duration:
        status = "TOO_LONG"
    elif ratio > 2.0:
        status = "SUSPICIOUS_LONG"
    elif ratio < 0.3:
        status = "SUSPICIOUS_SHORT"

    print(f"VERIFY: {os.path.basename(args.audio)}")
    print(f"  status: {status}")
    print(f"  actual_duration: {actual_duration:.2f}s")
    print(f"  expected_duration: {expected_duration:.2f}s")
    print(f"  max_duration: {max_duration:.2f}s")
    print(f"  ratio: {ratio:.2f}x")
    print(f"  file_size: {file_size} bytes")
    print(f"  word_count: {len(args.text.split())}")

    if status in ("TOO_LONG", "SUSPICIOUS_LONG") and args.trim:
        trim_to = min(max_duration, expected_duration * 1.5)
        print(f"  ACTION: Trimming to {trim_to:.2f}s")
        if _trim_audio(args.audio, trim_to):
            new_duration = _get_duration(args.audio)
            print(f"  TRIMMED: {actual_duration:.2f}s -> {new_duration:.2f}s")
        else:
            print(f"  TRIM_FAILED: Could not trim audio")

    if status == "OK":
        sys.exit(0)
    else:
        sys.exit(0)  # Non-zero only on hard errors, not quality warnings


if __name__ == "__main__":
    main()
