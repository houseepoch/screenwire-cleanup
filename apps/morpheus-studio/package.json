{
  "name": "morpheus-studio",
  "private": true,
  "version": "0.4.13",
  "description": "ScreenWire Morpheus desktop studio",
  "homepage": "https://github.com/houseepoch/screenwire-cleanup",
  "repository": {
    "type": "git",
    "url": "https://github.com/houseepoch/screenwire-cleanup.git"
  },
  "author": {
    "name": "houseepoch",
    "email": "houseepoch@users.noreply.github.com"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "wait-on tcp:5173 && electron --no-sandbox electron/main.mjs",
    "generate:icons": "python3 scripts/generate_installer_icons.py",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build",
    "pack": "npm run generate:icons && npm run build:web && electron-builder --dir --publish never",
    "dist": "npm run generate:icons && npm run build:web && electron-builder --publish never",
    "dist:linux": "npm run generate:icons && npm run build:web && electron-builder --linux AppImage deb --publish never",
    "dist:win": "npm run generate:icons && npm run build:web && electron-builder --win nsis --publish never",
    "dist:mac": "npm run generate:icons && npm run build:web && electron-builder --mac dmg zip --publish never",
    "electron:start": "electron --no-sandbox electron/main.mjs",
    "playwright:install": "playwright install chromium",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "smoke:local": "npm run build:web && electron --no-sandbox electron/smoke.mjs --seed e2e/fixtures/seed-story.md",
    "test:e2e:workflow": "npm run build:web && playwright test",
    "test:e2e:smoke": "npm run build:web && electron --no-sandbox electron/smoke.mjs --seed e2e/fixtures/seed-story.md",
    "test:e2e": "npm run test:e2e:workflow && npm run test:e2e:smoke",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "gsap": "^3.14.2",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.70.0",
    "react-resizable-panels": "^4.2.2",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^36.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "kimi-plugin-inspect-react": "^1.0.3",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "ai.screenwire.morpheus",
    "productName": "ScreenWire Studio",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json",
      "!src{,/**}",
      "!public{,/**}",
      "!e2e{,/**}",
      "!smoke{,/**}",
      "!*.md",
      "!tsconfig*.json",
      "!vite.config.ts",
      "!eslint.config.js",
      "!playwright.config.ts"
    ],
    "extraMetadata": {
      "main": "electron/main.mjs"
    },
    "extraResources": [
      {
        "from": "../../",
        "to": "backend",
        "filter": [
          "*.py",
          "requirements.txt",
          ".env.example",
          "agent_prompts/**/*",
          "graph/**/*",
          "handlers/**/*",
          "llm/**/*",
          "projects/_template/**/*",
          "skills/**/*",
          "!**/__pycache__/**",
          "!**/*.pyc"
        ]
      }
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "backgroundColor": "#070b14"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "category": "Graphics;Video",
      "icon": "build/icons",
      "maintainer": "houseepoch <houseepoch@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
